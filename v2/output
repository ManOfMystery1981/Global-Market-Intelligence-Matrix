<script>
// ══════════════════════════════════════════════════════════════════
// TAB SWITCHING
// ══════════════════════════════════════════════════════════════════
const TABS = ['dashboard','reports','pricing','analytics','compliance'];
function showTab(name) {
  TABS.forEach(t => {
    document.getElementById('content-'+t).classList.remove('active');
    const b = document.getElementById('tab-'+t);
    b.classList.remove('bg-emerald-500/10','text-emerald-400','border','border-emerald-500/30');
    b.classList.add('text-gray-500');
  });
  document.getElementById('content-'+name).classList.add('active');
  const ab = document.getElementById('tab-'+name);
  ab.classList.add('bg-emerald-500/10','text-emerald-400','border','border-emerald-500/30');
  ab.classList.remove('text-gray-500');
  if (name === 'analytics') initAnalytics();
}

// ══════════════════════════════════════════════════════════════════
// PAYMENT
// ══════════════════════════════════════════════════════════════════
let selPayment = 'stripe';
function selPay(m) {
  selPayment = m;
  ['stripe','crypto'].forEach(x => {
    const b = document.getElementById('pay-'+x);
    if (x === m) { b.style.border='2px solid #10b981'; b.style.background='#10b98112'; b.classList.add('text-white'); b.classList.remove('text-gray-400'); }
    else          { b.style.border='1px solid #1e293b'; b.style.background='transparent'; b.classList.remove('text-white'); b.classList.add('text-gray-400'); }
  });
}
function doCheckout() {
  const email = document.getElementById('order-email').value;
  const rtype = document.getElementById('report-type').value;
  if (!email || !email.includes('@')) { alert('Please enter a valid delivery email.'); return; }
  const btn = document.getElementById('checkout-btn');
  btn.textContent = 'Processing...'; btn.disabled = true;
  fetch('/api/checkout', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({email, report_type:rtype, payment_method:selPayment})
  }).then(r=>r.json()).then(d=>{
    if (d.checkout_url) window.open(d.checkout_url,'_blank');
    else alert('Order received. You will be contacted within 24 hours.');
  }).catch(()=>{
    window.open(selPayment==='stripe' ? 'https://buy.stripe.com/YOUR_LINK' : 'https://hel.io/YOUR_LINK','_blank');
  }).finally(()=>{ btn.textContent='$2,500 — Secure Checkout'; btn.disabled=false; });
}

// ══════════════════════════════════════════════════════════════════
// CHART ENGINE — jagged lightning tick charts
// ══════════════════════════════════════════════════════════════════
const MAX_PTS = 120;
const charts  = {};

function seedChart(id, color, seedPrice) {
  const canvas = document.getElementById('cv-'+id);
  if (!canvas) return;
  canvas.width = canvas.parentElement.clientWidth - 32;
  const ctx = canvas.getContext('2d');
  const history = [];
  let p = seedPrice;
  for (let i = 0; i < MAX_PTS; i++) {
    p = p * (1 + (Math.random()-0.499)*0.0008);
    history.push(p);
  }
  charts[id] = { ctx, history, color, canvas, lastPrice: seedPrice };
  drawChart(id);
}

function seedDualChart(id, series) {
  // series = [{data:[...], color:'#hex'}, ...]
  const canvas = document.getElementById('cv-'+id);
  if (!canvas) return;
  canvas.width = canvas.parentElement.clientWidth - 32;
  const ctx = canvas.getContext('2d');
  charts[id] = { ctx, canvas, series, type:'dual' };
  drawDualChart(id);
}

function pushPrice(id, price) {
  const c = charts[id];
  if (!c || c.type==='dual') return;
  c.history.push(price);
  if (c.history.length > MAX_PTS) c.history.shift();
  c.lastPrice = price;
  drawChart(id);
}

function drawChart(id) {
  const c = charts[id];
  if (!c || c.type==='dual') return;
  const { ctx, history, canvas } = c;
  const W = canvas.width, H = canvas.height, pad = 8;
  ctx.clearRect(0,0,W,H);
  if (history.length < 2) return;
  const min = Math.min(...history), max = Math.max(...history), range = max-min||1;
  const xStep = W/(MAX_PTS-1);
  const isUp = history[history.length-1] >= history[0];
  const lc = isUp ? '#10b981' : '#f43f5e';
  const gc = isUp ? '#10b98130' : '#f43f5e30';

  ctx.shadowBlur = 6; ctx.shadowColor = lc;
  ctx.beginPath();
  history.forEach((v,i) => {
    const x = i*xStep, y = H-pad-((v-min)/range)*(H-pad*2);
    i===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
  });
  ctx.strokeStyle = lc; ctx.lineWidth = 1.5; ctx.lineJoin='round'; ctx.stroke();

  // fill
  ctx.shadowBlur = 0;
  const lx = (history.length-1)*xStep;
  ctx.lineTo(lx,H); ctx.lineTo(0,H); ctx.closePath();
  const g = ctx.createLinearGradient(0,0,0,H);
  g.addColorStop(0,gc); g.addColorStop(1,'transparent');
  ctx.fillStyle=g; ctx.fill();

  // current price label
  const lv = history[history.length-1];
  const ly = H-pad-((lv-min)/range)*(H-pad*2);
  ctx.fillStyle=lc; ctx.font='8px JetBrains Mono,monospace'; ctx.textAlign='right';
  ctx.fillText(lv>100?'$'+lv.toFixed(2):'$'+lv.toFixed(4), W-2, Math.max(10,ly-3));
}

function drawDualChart(id) {
  const c = charts[id];
  if (!c || c.type!=='dual') return;
  const { ctx, canvas, series } = c;
  const W = canvas.width, H = canvas.height, pad = 12;
  ctx.clearRect(0,0,W,H);
  const allVals = series.flatMap(s=>s.data);
  const min = Math.min(...allVals), max = Math.max(...allVals), range = max-min||1;
  const N = series[0].data.length;
  const xStep = W/(N-1);

  series.forEach(s => {
    ctx.shadowBlur = 4; ctx.shadowColor = s.color;
    ctx.beginPath();
    s.data.forEach((v,i) => {
      const x=i*xStep, y=H-pad-((v-min)/range)*(H-pad*2);
      i===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    });
    ctx.strokeStyle=s.color; ctx.lineWidth=1.5; ctx.lineJoin='round'; ctx.stroke();
    ctx.shadowBlur=0;
  });
}

function simTick(id, volatility=0.0006) {
  const c = charts[id];
  if (!c || c.type==='dual') return;
  const last = c.lastPrice;
  const spike = Math.random()<0.04 ? (Math.random()-0.5)*0.003 : 0;
  const next = last*(1+(Math.random()-0.499)*volatility+spike);
  pushPrice(id, next);
  const pe = document.getElementById('c-'+id+'-p');
  if (pe) pe.textContent = '$'+next.toFixed(next>100?2:4);
}

// Generate 30-day macro series (simulated FRED-style slow data)
function buildMacroSeries(base, volatility, N=60) {
  const arr=[];
  let v=base;
  for(let i=0;i<N;i++){
    v+=( Math.random()-0.499)*volatility;
    arr.push(parseFloat(v.toFixed(3)));
  }
  return arr;
}

let analyticsReady = false;
let simInterval = null;

function initAnalytics() {
  if (analyticsReady) return;
  analyticsReady = true;

  // Seed all 12 tick charts
  const cryptoSeeds = {btc:43256.78,eth:2356.42,sol:98.32,bnb:312.67,xrp:0.623,avax:34.21};
  const equitySeeds = {nvda:875.40,spy:524.18,qqq:448.92,gld:224.67,tlt:93.42,uso:78.14};
  Object.entries(cryptoSeeds).forEach(([id,p])=>seedChart(id,'#10b981',p));
  Object.entries(equitySeeds).forEach(([id,p])=>seedChart(id,'#f59e0b',p));

  // Yield curve dual chart (2Y vs 10Y)
  const t2y = buildMacroSeries(4.89, 0.02);
  const t10y = buildMacroSeries(4.68, 0.015);
  seedDualChart('yieldcurve', [
    { data: t2y,  color: '#8b5cf6' },
    { data: t10y, color: '#06b6d4' },
  ]);

  // Fed vs CPI dual chart
  const fed = buildMacroSeries(5.33, 0.005);
  const cpi = buildMacroSeries(3.10, 0.02);
  seedDualChart('fedcpi', [
    { data: fed, color: '#10b981' },
    { data: cpi, color: '#f59e0b' },
  ]);

  // Simulate equity ticks every 1.8s (realistic for 15s real-data polling)
  simInterval = setInterval(() => {
    Object.keys(equitySeeds).forEach(id => simTick(id, 0.0005));
  }, 1800);

  // Try to get real equity data from Flask backend if available
  tryRealEquityFeed();

  // Start Binance WebSocket for real crypto
  connectBinance();
}

// ── Real equity data from Flask (when Finnhub key is set) ─────────────────
function tryRealEquityFeed() {
  const tickers = ['nvda','spy','qqq','gld','tlt','uso'];
  function fetchEquity() {
    fetch('/api/equity-snapshot')
      .then(r=>r.json())
      .then(data => {
        tickers.forEach(id => {
          if (data[id.toUpperCase()]) {
            const price = data[id.toUpperCase()].price;
            pushPrice(id, price);
            const pe = document.getElementById('c-'+id+'-p');
            const ce = document.getElementById('c-'+id+'-c');
            if (pe) pe.textContent = '$'+price.toFixed(2);
            if (ce) {
              const chg = data[id.toUpperCase()].change_pct;
              ce.textContent=(chg>=0?'+':'')+chg.toFixed(2)+'%';
              ce.style.color = chg>=0?'#10b981':'#f43f5e';
            }
            // Switch badge to live
            document.querySelectorAll('.badge-sim').forEach(b=>{ b.textContent='Live'; b.className='badge-live'; });
          }
        });
      })
      .catch(()=>{}); // silently fall back to simulation if Flask not running
  }
  setInterval(fetchEquity, 15000); // poll every 15s
  fetchEquity();
}

// ── Binance WebSocket for real crypto ────────────────────────────────────────
function connectBinance() {
  const streams = ['btcusdt','ethusdt','solusdt','bnbusdt','xrpusdt','avaxusdt']
    .map(s=>s+'@trade').join('/');
  const ws = new WebSocket('wss://stream.binance.com:9443/stream?streams='+streams);

  ws.onmessage = e => {
    try {
      const d = JSON.parse(e.data).data;
      if (!d||!d.s) return;
      const id  = d.s.replace('USDT','').toLowerCase();
      const price = parseFloat(d.p);
      pushPrice(id, price);
      const fmt = price>10 ? '$'+price.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) : '$'+price.toFixed(4);
      // Update ticker bar
      const te = document.getElementById('t-'+id); if(te) te.textContent=fmt;
      // Update analytics label
      const pe = document.getElementById('c-'+id+'-p'); if(pe) pe.textContent=fmt;
      // Update dashboard
      const de = document.getElementById('d-'+id); if(de) de.textContent=fmt;
    } catch(e){}
  };

  // Ticker stream for 24h change %
  const ws2 = new WebSocket('wss://stream.binance.com:9443/stream?streams='+
    ['btcusdt','ethusdt','solusdt','bnbusdt','xrpusdt','avaxusdt'].map(s=>s+'@ticker').join('/'));
  ws2.onmessage = e => {
    try {
      const d = JSON.parse(e.data).data;
      if (!d||!d.s) return;
      const id  = d.s.replace('USDT','').toLowerCase();
      const chg = parseFloat(d.P);
      const col = chg>=0?'#10b981':'#f43f5e';
      const str = (chg>=0?'+':'')+chg.toFixed(2)+'%';
      ['t-','c-','d-'].forEach(pfx=>{
        const sfx = pfx==='c-' ? '-c' : '-c';
        const el = document.getElementById(pfx+id+(pfx==='t-'?'-c':'-c'));
        if(el){ el.textContent=str; el.style.color=col; }
      });
    } catch(e){}
  };

  ws.onerror=()=>ws.close();
  ws.onclose=()=>setTimeout(connectBinance,5000);
}

// Resize canvases on window resize
window.addEventListener('resize', ()=>{
  if(!analyticsReady) return;
  Object.keys(charts).forEach(id=>{
    const c=charts[id];
    if(!c) return;
    c.canvas.width = c.canvas.parentElement.clientWidth-32;
    if(c.type==='dual') drawDualChart(id);
    else drawChart(id);
  });
});
